{
    "name": "wordplay",
    "version": "0.26.2",
    "type": "module",
    "scripts": {
        "sync": "svelte-kit sync",
        "postinstall": "run-script-os",
        "postinstall:default": "npm run sync && cp .env.template .env && npm run updates && npm run fonts-build",
        "postinstall:windows": "npm run sync && copy .env.template .env && npm run updates && npm run fonts-build",
        "check": "svelte-check --tsconfig ./tsconfig.json --watch .svelte-kit",
        "check:now": "svelte-check --tsconfig ./tsconfig.json .svelte-kit",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "end2end": "npm run build && firebase emulators:exec \"npx playwright test\" --project=demo-wordplay --log-verbosity QUIET",
        "dev": "vite dev",
        "emu": "npx tsx scripts/seed.ts & firebase emulators:start --project=demo-wordplay",
        "env": "run-script-os",
        "env:default": "cp .env.${GCLOUD_PROJECT:-template} .env",
        "env:windows": "copy .env.template .env",
        "build": "npm upgrade shared-types && npm run env && npm run updates && npm run how && npm run mediapipe && npm run fonts-build && vite build && (cd functions && npm run build)",
        "build:ci": "npm run env && npm run updates && npm run how && npm run mediapipe && npm run fonts-build && vite build && (cd functions && npm run build)",
        "build:web": "npm run env && npm run updates && npm run how && npm run mediapipe && npm run fonts-build && vite build",
        "preview": "vite preview",
        "stage": "firebase use dev && firebase deploy && npm run env",
        "release": "firebase use prod && firebase deploy && firebase use dev && npm run env",
        "tutorial-schema": "npx ts-json-schema-generator --no-type-check --tsconfig tsconfig.json --path 'src/tutorial/Tutorial.ts' --type 'Tutorial' --out static/schemas/Tutorial.json",
        "locale-schema": "npx ts-json-schema-generator --no-type-check --tsconfig tsconfig.json --path 'src/locale/LocaleText.ts' --type 'LocaleText' --out static/schemas/LocaleText.json && npx tsx src/util/verify-locales/generate-template-inputs.ts",
        "datetime-schema": "npx ts-json-schema-generator --no-type-check --tsconfig tsconfig.json --path 'src/locale/dateTimeFormats.ts' --type 'DateTimeData' --out static/schemas/DateTimeData.json",
        "create-schemas": "npm run tutorial-schema && npm run locale-schema && npm run datetime-schema",
        "locales": "npx tsx src/util/verify-locales/start.ts verify",
        "locales-fix": "npx tsx src/util/verify-locales/start.ts fix",
        "locales-prune": "npx tsx src/util/verify-locales/prune.ts",
        "datetimes": "npx tsx src/util/verify-locales/generateDateTimes.ts",
        "exemplars": "npx tsx src/util/verify-locales/generateExemplars.ts",
        "locales-translate": "WORDPLAY_TRANSLATOR=claude npx tsx src/util/verify-locales/start.ts translate",
        "locales-override": "WORDPLAY_TRANSLATOR=claude npx tsx src/util/verify-locales/start.ts override",
        "locales-translate-parallel": "WORDPLAY_TRANSLATOR=claude npx tsx src/util/verify-locales/batch.ts translate",
        "locales-override-parallel": "WORDPLAY_TRANSLATOR=claude npx tsx src/util/verify-locales/batch.ts override",
        "locales-emojis": "npx tsx src/util/verify-locales/generateEmojis.ts",
        "how": "npx tsx src/util/verify-locales/buildHowTos.ts",
        "codes": "npx tsx src/unicode/compress.ts",
        "emoji-update": "npx tsx scripts/emoji/update.ts",
        "fonts": "npx tsx scripts/fonts/start.ts verify",
        "fonts-build": "npx tsx scripts/fonts/start.ts build && npx prettier --write static/fonts/fonts.css static/fonts/fonts-fallback.css src/basis/faces/faces.generated.ts",
        "fonts-fix": "npx tsx scripts/fonts/start.ts fix && npx prettier --write static/fonts/fonts.css static/fonts/fonts-fallback.css src/basis/faces/faces.generated.ts src/basis/faces/faces.fallback.generated.ts src/basis/faces/renderable.generated.ts",
        "fonts-download": "npx tsx scripts/fonts/start.ts download && npx prettier --write static/fonts/fonts.css static/fonts/fonts-fallback.css src/basis/faces/faces.generated.ts src/basis/faces/renderable.generated.ts",
        "rtl": "npx tsx scripts/check-logical-css.ts",
        "schemas": "npm-watch create-schemas",
        "merge": "git checkout main && git merge dev && git push origin main && git checkout dev",
        "outdated": "npx check-outdated --ignore-pre-releases --columns name,type,current,latest,changes",
        "updates": "npx tsx scripts/updates.ts",
        "mediapipe": "node scripts/copy-wasm.mjs",
        "claims": "node scripts/claims.js ",
        "contributors": "npx tsx functions/src/refresh-contributors-local.ts"
    },
    "engines": {
        "node": "^22.0.0"
    },
    "watch": {
        "verify-locales": {
            "patterns": [
                "src/locale/en-US.json",
                "static/locales",
                "static/schemas",
                "verify-locales.ts"
            ],
            "extensions": "json,ts",
            "quiet": true
        },
        "create-schemas": {
            "patterns": [
                "src/locale"
            ],
            "extensions": "ts",
            "ignore": "src/locale/templateInputs.generated.ts",
            "quiet": true
        }
    },
    "devDependencies": {
        "@google-cloud/translate": "^9",
        "@playwright/test": "^1",
        "@sveltejs/adapter-static": "^3",
        "@sveltejs/kit": "^2",
        "@sveltejs/vite-plugin-svelte": "^7",
        "ajv": "^8",
        "chalk": "^5",
        "firebase-admin": "^14",
        "firebase-tools": "^15",
        "npm-watch": "^0",
        "prettier": "^3",
        "prettier-plugin-svelte": "^4",
        "run-script-os": "^1",
        "svelte": "^5",
        "svelte-check": "^4",
        "svelte-jester": "^5",
        "ts-json-schema-generator": "^2",
        "tslib": "^2",
        "tsx": "^4",
        "typescript": "^6",
        "vite": "^8",
        "vitest": "^4"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0",
        "@axe-core/playwright": "^4",
        "@dimforge/rapier2d-compat": "^0.19.3",
        "@mediapipe/tasks-vision": "^0",
        "@types/fontkit": "^2",
        "colorjs.io": "^0",
        "decimal.js": "^10",
        "dexie": "^4",
        "dotenv": "^17",
        "firebase": "^12",
        "fontkit": "^2",
        "highlight.js": "^11",
        "picomatch": "^4",
        "pitchy": "^4",
        "shared-types": "file:./functions/src/shared",
        "temporal-polyfill": "^1",
        "uuid": "^14",
        "yjs": "^13",
        "zod": "^4"
    },
    "overrides": {
        "cookie": "^0.7.0",
        "jwks-rsa": {
            "jose": "^5.10.0"
        }
    },
    "browserslist": [
        "defaults",
        "not op_mini all"
    ],
    "bundleDependencies": [
        "shared-types"
    ]
}
